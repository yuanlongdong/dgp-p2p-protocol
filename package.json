{
"name": "dgp-p2p",
"private": true,
"version": "0.1.0",
"packageManager": "pnpm@9.0.0",
"scripts": {
"build": "pnpm -r build",
"dev:web": "pnpm --filter @dgp/web dev",
"dev:miniapp": "pnpm --filter @dgp/miniapp dev",
"test:contracts": "pnpm --filter @dgp/contracts test",
"subgraph:codegen": "pnpm --filter @dgp/subgraph codegen",
"subgraph:build": "pnpm --filter @dgp/subgraph build",
"subgraph:sync:arb": "pnpm --filter @dgp/subgraph sync:arb",
"subgraph:sync:op": "pnpm --filter @dgp/subgraph sync:op",
"demo:prepare": "node scripts/ops/prepare-demo-env.mjs",
"demo:prepare:arb": "node scripts/ops/prepare-demo-env.mjs arbSepolia",
"demo:prepare:op": "node scripts/ops/prepare-demo-env.mjs opSepolia"
}
}
