{
  "name": "dgp-p2p",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev:web": "pnpm --filter @dgp/web dev",
    "dev:miniapp": "pnpm --filter @dgp/miniapp dev",
    "dev:bot": "pnpm --filter @dgp/telegram-bot start",
    "dev:compliance-gateway": "pnpm --filter @dgp/compliance-gateway start",
    "test:contracts": "pnpm --filter @dgp/contracts test",
    "subgraph:codegen": "pnpm --filter @dgp/subgraph codegen",
    "subgraph:build": "pnpm --filter @dgp/subgraph build",
    "subgraph:sync:arb": "pnpm --filter @dgp/subgraph sync:arb",
    "subgraph:sync:op": "pnpm --filter @dgp/subgraph sync:op",
    "demo:prepare": "node scripts/ops/prepare-demo-env.mjs",
    "demo:prepare:arb": "node scripts/ops/prepare-demo-env.mjs arbSepolia",
    "demo:prepare:op": "node scripts/ops/prepare-demo-env.mjs opSepolia",
    "demo:e2e:arb": "node scripts/ops/e2e-demo.mjs arbSepolia",
    "demo:e2e:op": "node scripts/ops/e2e-demo.mjs opSepolia",
    "ops:healthcheck:arb": "node scripts/ops/healthcheck.mjs arbSepolia",
    "ops:healthcheck:op": "node scripts/ops/healthcheck.mjs opSepolia",
    "ops:takeover:check": "pnpm build && pnpm test:contracts",
    "security:baseline": "node scripts/security/baseline-check.mjs",
    "ops:healthcheck:arb:strict": "HEALTHCHECK_STRICT=1 node scripts/ops/healthcheck.mjs arbSepolia",
    "ops:healthcheck:op:strict": "HEALTHCHECK_STRICT=1 node scripts/ops/healthcheck.mjs opSepolia",
    "security:monitor:p2p": "node scripts/security/monitor-p2p-trade-arbitration.mjs",
    "security:audit:weekly:p2p": "node scripts/security/weekly-audit-p2p-trade-arbitration.mjs",
    "security:patch:proposal:p2p": "node scripts/security/generate-patch-proposal.mjs",
    "security:audit:summary:p2p": "node scripts/security/generate-audit-summary.mjs",
    "security:workflow:p2p": "node scripts/security/run-p2p-contract-workflow.mjs",
    "security:coi:check": "node scripts/security/conflict-of-interest-check.mjs"
  }
}
